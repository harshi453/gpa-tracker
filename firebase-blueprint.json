export const HOUSE_IDEAS: HouseIdea[] = Array.from({ length: 100 }, (_, i) => {
  const style = styles[i % styles.length];
  const adj = adjectives[Math.floor(Math.random() * adjectives.length)];
  const source = sources[Math.floor(Math.random() * sources.length)];
  const id = (i + 1).toString();
  const unsplashId = unsplashIds[i % unsplashIds.length];
  
  return {
    id,
    title: `${adj} ${style.name} ${i % 2 === 0 ? 'Home' : 'Villa'}`,
    description: `A beautiful example of ${style.name} architecture featuring ${style.tags.join(', ')} elements.`,
    image: `https://images.unsplash.com/photo-${unsplashId}?auto=format&fit=crop&w=800&q=80&sig=${id}`,
    source,
    url: source === 'Pinterest' 
      ? `https://www.pinterest.com/search/pins/?q=${encodeURIComponent(style.name + ' house design')}`
      : `https://www.google.com/search?q=${encodeURIComponent(style.name + ' house architecture')}&tbm=isch`,
    tags: style.tags
  };
});
