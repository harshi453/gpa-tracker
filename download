import React from 'react';
import { Room } from '../../types';
import { motion } from 'motion/react';

interface RoomLegendProps {
  rooms: Room[];
}

export const RoomLegend: React.FC<RoomLegendProps> = ({ rooms }) => {
  return (
    <div className="space-y-4">
      <h3 className="text-sm font-bold text-app-text uppercase tracking-wider flex items-center gap-2">
        <div className="w-1 h-4 bg-brand rounded-full" />
        Room Details
      </h3>
      <div className="grid grid-cols-1 gap-2">
        {rooms.map((room, i) => (
          <motion.div 
            key={i} 
            initial={{ opacity: 0, x: -10 }}
            animate={{ opacity: 1, x: 0 }}
            transition={{ delay: i * 0.1 }}
            className="flex items-center justify-between p-2 rounded-lg bg-app-bg/50 border border-app-border"
          >
            <div className="flex items-center gap-3">
              <div className="w-2 h-2 rounded-full" style={{ backgroundColor: getRoomColor(room.type) }} />
              <span className="text-sm font-medium text-app-text/80">{room.name}</span>
            </div>
            <span className="text-xs text-app-text/40">{room.width}m x {room.depth}m</span>
          </motion.div>
        ))}
      </div>
    </div>
  );
};

const getRoomColor = (type: Room['type']) => {
  switch (type) {
    case 'living': return '#fef3c7';
    case 'bedroom': return '#ecfdf5';
    case 'kitchen': return '#fff7ed';
    case 'bathroom': return '#eff6ff';
    case 'dining': return '#fff1f2';
    case 'hallway': return '#f8fafc';
    case 'garage': return '#f1f5f9';
    default: return '#ffffff';
  }
};
